# PostgreSQL connection string from your hosted provider (Neon / Supabase / Railway)
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Optional direct PostgreSQL connection for migrations/seed. Supabase users should put the non-pgbouncer URL here.
DIRECT_URL=

# Secret used to sign JWT tokens - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# SMTP credentials for sending emails (use Resend, Brevo, or Gmail OAuth in production)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Your public web URL (no trailing slash)
WEB_URL=http://localhost:3000

# Optional production cookie domain for cross-subdomain auth, e.g. .cracked.dev
COOKIE_DOMAIN=

# Cookie SameSite policy. Use strict for same-site custom domains; use none for separate Render preview domains.
COOKIE_SAMESITE=strict

# Express server port
PORT=4000

# Initial superadmin seed values. Password is required only when running pnpm db:seed.
SEED_ADMIN_EMAIL=admin@cracked.dev
SEED_ADMIN_PASSWORD=
